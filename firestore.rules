rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────
    // permissionLevel in users collection:
    //   6 = SuperAdmin, 5 = Admin → AM Admin
    //   3-4 = Approver/Manager   → AM Manager
    //   1-2 = Requester/Viewer   → AM Viewer

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function permLevel() {
      return userDoc().permissionLevel;
    }

    function isAdmin() {
      return isAuthenticated() && permLevel() >= 5;
    }

    function isManager() {
      return isAuthenticated() && permLevel() >= 3;
    }

    function isViewer() {
      return isAuthenticated();
    }

    // PR-style admin: permissionLevel 1 = SuperAdmin, 8 = User Admin.
    // (Distinct from the AM-style isAdmin() helper above, which uses
    // the AM permission scheme for AM collections.)
    function isPrAdmin() {
      return isAuthenticated()
        && (permLevel() == 1 || permLevel() == 8);
    }

    // Fields HR owns once a user is linked (hrEmployeeId is set).
    // Clients may not change these on a linked user; only server-side
    // Cloud Functions (using the Admin SDK, which bypasses these rules)
    // may write them.
    //
    // NOTE: `department` (PR dept id) is intentionally PR-owned here —
    // multi-department appointments and primary-department overrides are
    // managed in PR. The HR-owned name is mirrored to `hrDepartmentName`.
    //
    // Enforcement is via preservesHrOwnedFields() below: an update to a
    // linked user may only change the PR-owned keys in its allow-list.
    function isHrLinked() {
      return resource.data.hrEmployeeId != null
        && resource.data.hrEmployeeId != '';
    }
    // On an HR-linked user, the update must not touch any HR-owned field.
    function preservesHrOwnedFields() {
      return isHrLinked()
        ? request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['permissionLevel', 'organization', 'additionalOrganizations',
                      'isActive', 'isHrLead', 'hrLeadCountryCodes',
                      'multiDepartmentAppointmentsEnabled', 'departmentMemberships',
                      'department',
                      'name', 'createdAt', 'updatedAt', 'id'])
        : true;
    }

    // ── AM core collections ─────────────────────────────────────

    match /am_core_assets/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /am_core_allocations/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /am_core_transactions/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if false;
      allow delete: if false;
    }

    match /am_core_inventory_levels/{docId} {
      allow read:   if isViewer();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // ── AM PR master / shared collections ───────────────────────

    match /pr_master_categories/{docId} {
      allow read:   if isViewer();
      allow write:  if isAdmin();
    }

    match /pr_master_countries/{docId} {
      allow read:   if isViewer();
      allow write:  if isAdmin();
    }

    match /pr_master_locations/{docId} {
      allow read:   if isViewer();
      allow write:  if isAdmin();
    }

    match /pr_master_requests/{docId} {
      allow read:   if isViewer();
      allow create: if isViewer();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /pr_master_employees/{docId} {
      allow read:  if isViewer();
      allow write: if isAdmin();
    }

    // ── User profiles ───────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Self-update, superadmin (PR permission level 1), or HR Lead managing other profiles.
      // HR-owned fields are protected by preservesHrOwnedFields() once a user
      // is linked to HR (hrEmployeeId set). Cloud Functions write via the
      // Admin SDK and bypass these rules entirely.
      allow update: if (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissionLevel == 1
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isHrLead == true)
        && preservesHrOwnedFields();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── HR employee sync (server-written, admin-read) ──────────────────

    match /hrReconciliationReports/{docId} {
      allow read: if isPrAdmin();
      allow write: if false; // written only by Cloud Functions via Admin SDK
    }

    match /hrDepartmentSyncReports/{docId} {
      allow read: if isPrAdmin();
      allow write: if false; // written only by Cloud Functions via Admin SDK
    }

    match /hrSyncState/{docId} {
      allow read: if isPrAdmin();
      allow write: if false; // written only by Cloud Functions via Admin SDK
    }

    // ── Department catalog (HR is canonical as of 2026-06-30) ──────────
    // PR mirrors HR's /api/departments into this collection via Cloud
    // Functions (Admin SDK). Clients may read for pickers/filters but may
    // NOT write — department edits belong in the HR portal.
    match /referenceData_departments/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── PR System reference data collections ────────────────────

    match /departments/{docId} {
      allow read, write: if true;
    }

    match /projectCategories/{docId} {
      allow read, write: if true;
    }

    match /sites/{docId} {
      allow read, write: if true;
    }

    match /expenseTypes/{docId} {
      allow read, write: if true;
    }

    match /vehicles/{docId} {
      allow read, write: if true;
    }

    match /vendors/{docId} {
      allow read, write: if true;
    }

    match /currencies/{docId} {
      allow read, write: if true;
    }

    // ── PR System purchase requests ─────────────────────────────

    match /purchaseRequests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.requestorId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.permissionLevel <= 4);
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.permissionLevel <= 2;
    }

    // ── PO cap audit trail (25 approved PO limit) ───────────────

    match /poCapAudit/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── PR System archive ───────────────────────────────────────

    match /archivePRs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Job Cards ───────────────────────────────────────────────

    match /jobCards/{jobCardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Field Camp Provisioning (org-scoped reference data + logged plans) ──
    // The catch-all below also grants authenticated access; these explicit
    // rules document the intended access shape. Ration catalog / menus /
    // defaults / prices are admin/procurement-managed; plans are writable by
    // any authenticated org member (procurement owns the workflow).

    match /referenceData_rations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isPrAdmin() || permLevel() == 3; // admin or procurement
    }
    match /referenceData_provisioningMenus/{docId} {
      allow read: if isAuthenticated();
      allow write: if isPrAdmin() || permLevel() == 3;
    }
    match /referenceData_provisioningDefaults/{docId} {
      allow read: if isAuthenticated();
      allow write: if isPrAdmin();
    }
    match /referenceData_rationPrices/{docId} {
      allow read: if isAuthenticated();
      allow write: if isPrAdmin() || permLevel() == 3 || permLevel() == 4 || permLevel() == 6;
    }

    match /provisioningPlans/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isPrAdmin() || permLevel() == 3;
    }

    // ── Catch-all: allow authenticated access to any other
    //    collection (referenceData_*, etc.) ───────────────────────

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
